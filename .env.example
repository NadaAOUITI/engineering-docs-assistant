# Copy to .env and adjust. Pydantic Settings reads these (see app/core/config.py).

# PostgreSQL (SQLAlchemy URL; requires pgvector extension enabled on the database)
DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/engineering_docs

# Redis (Celery broker and result backend)
REDIS_URL=redis://localhost:6379/0

# JWT (use a long random secret in production)
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Groq LLM API
GROQ_API_KEY=

# Local embeddings (sentence-transformers model id)
EMBEDDING_MODEL_NAME=sentence-transformers/all-mpnet-base-v2
